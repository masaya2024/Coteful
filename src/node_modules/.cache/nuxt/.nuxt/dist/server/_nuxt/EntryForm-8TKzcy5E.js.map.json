3B,QAAQ,MAAM,OAAO,UAAU;AAAA,MAC/B,QAAS,MAAM,OAAO,SAAS,gBAAgB,MAAM,MAAM,MAAM,IAAI,yBAAyB,MAAM,KAAK;AAAA,IAAA,CAC1G;AAED;AAAA,MACE,MAAM,MAAM;AAAA,MACZ,CAAA,UAAS;AACP,YAAI,CAAC,OAAO;AACV;AAAA,QACF;AAEA,wBAAgB,QAAQ,MAAM;AAC9B,aAAK,QAAQ,MAAM;AACnB,aAAK,OAAO,MAAM;AAClB,aAAK,SAAS,MAAM;AACpB,aAAK,SAAS,gBAAgB,MAAM,MAAM;AAAA,MAC5C;AAAA,MACA,EAAE,WAAW,KAAA;AAAA,IAAK;AAGpB,UAAM,OAAO,CAAA,cAAa;AACxB,UAAI,CAAC,WAAW;AACd;AAAA,MACF;AAEA,YAAM,aAAa,yBAAyB,SAAS;AACrD,iBAAW,SAAS,UAAU,QAAQ;AACpC,YAAI,MAAM,OAAO,KAAK,QAAQ;AAC5B,qBAAW,MAAM,GAAG,IAAI,KAAK,OAAO,MAAM,GAAG;AAAA,QAC/C;AAAA,MACF;AACA,WAAK,SAAS;AAAA,IAChB,GAAG,EAAE,WAAW,MAAM;AAEtB;AAAA,MACE,MAAM,KAAK;AAAA,MACX,CAAA,UAAS;AACP,YAAI,MAAM,OAAO;AACf;AAAA,QACF;AAEA,cAAM,YAAY,eAAe,MAAM,OAAO,KAAK;AACnD,YAAI,WAAW;AACb,eAAK,QAAQ;AACb,eAAK,OAAO,cAAc,SAAS;AAAA,QACrC;AAAA,MACF;AAAA,MACA,EAAE,MAAM,KAAA;AAAA,IAAK;;;;oBAePF,eAAAC,WAAA,EAAA,OAAM,kDAAA,GAAiD,MAAA,CAAA,qKAIxBE,MAAA,CAAA,EAAC,iBAAA,CAAA,sCACmCG,sBAAA,QAAQ,QAAA,KAAK,CAAA,IAAA,cAAA;AACrDD,oBAAA,QAAA,SAAR,SAAI;sCAA4B,SAAO,KAAK,EAAE,wCAD9CF,MAAA,eAAA,CAAe,oBAAfA,MAAA,eAAA,GACuC,KAAK,EAAE,kBAD9CA,MAAA,eAAA,GACuC,KAAK,EAAE,CAAA,IAAA,cAAA,MACxDD,eAAA,KAAK,IAAI;;kHAMaC,MAAA,CAAA,EAAC,iBAAA,CAAA,iBACdC,cAAA,SAAAD,MAAA,IAAA,EAAK,KAAK,uBAAsBC,cAAA,eAAaD,MAAA,CAAA,EAAC,iBAAA,CAAA,gKAMjCA,MAAA,CAAA,EAAC,gBAAA,CAAA,iBACdC,cAAA,SAAAD,MAAA,IAAA,EAAK,IAAI,mIAIIA,MAAA,CAAA,EAAC,kBAAA,CAAA;AAEHE,oBAAA,QAAA,gBAAV,WAAM;sCAAwC,SAAO,OAAO,KAAK,IADjEC,sBAAA,MAAA,QAAAH,MAAA,IAAA,EAAK,MAAM,IAAXI,gBAAAJ,MAAA,IAAA,EAAK,QACgD,OAAO,KAAK,IADjEK,cAAAL,MAAA,IAAA,EAAK,QACgD,OAAO,KAAK,CAAA,IAAA,cAAA,MAC3ED,eAAA,OAAO,KAAK;;;UAMRC,MAAA,KAAA,GAAK;+MAITA,MAAA,CAAA,EAAC,yBAAA,CAAA,kEAGDD,eAAAC,MAAA,KAAA,EAAM,IAAI,kCAGKD,eAAAC,MAAA,KAAA,EAAM,KAAK;;UAGN,YAAAA,MAAA,IAAA,EAAK;AAAA,UAAL,uBAAA,CAAA,WAAAA,MAAA,IAAA,EAAK,SAAM;AAAA,UAAG,OAAOA,MAAA,KAAA;AAAA,UAAQ,eAAa,QAAA;AAAA,UAAa,SAAS,QAAA;AAAA,QAAA;;;;;mLAOxFA,MAAA,CAAA,EAAC,0BAAA,CAAA,sHAGuCA,MAAA,CAAA,EAAC,wBAAA,CAAA,qBAAoED,eAAA,mBAAAC,MAAA,KAAA,GAAO,SAAK,cAAA,IAAsB,QAAA,OAAO,MAAE,UAAA,EAAA,sEAChHA,MAAA,CAAA,EAAC,kBAAA,CAAA,8BAAqCA,MAAA,CAAA,EAAC,UAAWA,MAAA,IAAA,EAAK,MAAM,EAAA,CAAA,+DAC7DA,MAAA,CAAA,EAAC,eAAA,CAAA,eAAkCD,eAAA,OAAO,KAAKC,YAAK,MAAM,EAAE,MAAM,oBAAOA,MAAA,CAAA,EAAC,uBAAA,CAAA,iHAMlHA,MAAA,CAAA,EAAC,kBAAA,CAAA;;QAGE,MAAK;AAAA,QAAc,MAAK;AAAA,MAAA;+BAC3B,QAAA,WAAW,CAAA,gCAAA;AAAA;;;;;;;;;;","names":["_useModel","_ssrRenderAttrs","_mergeProps","_ssrInterpolate","_unref","_ssrRenderAttr","_ssrRenderList","_ssrIncludeBooleanAttr","_ssrLooseContain","_ssrLooseEqual"],"sources":["../../../../../../../components/EntryFieldRenderer.vue","../../../../../../../components/EntryForm.vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport type { ContentEntry, ContentModel, MediaItem } from '~/types'\nimport { mediaLabel, referenceEntriesForField } from '~/utils/content'\nconst { t } = useLocale()\n\nconst props = defineProps<{\n  model: ContentModel\n  mediaItems: MediaItem[]\n  entries: ContentEntry[]\n}>()\n\nconst entryFields = defineModel<Record<string, unknown>>({ required: true })\n\nfunction updateField(key: string, value: unknown) {\n  entryFields.value = {\n    ...entryFields.value,\n    [key]: value,\n  }\n}\n\nfunction asJsonText(value: unknown) {\n  if (typeof value === 'string') {\n    return value\n  }\n\n  return JSON.stringify(value ?? {}, null, 2)\n}\n</script>\n\n<template>\n  <div class=\"space-y-5\">\n    <div\n      v-for=\"field in model.fields\"\n      :key=\"field.id\"\n      class=\"space-y-2 text-sm\"\n    >\n      <label class=\"flex items-center justify-between\">\n        <span class=\"font-medium\">{{ field.name }}</span>\n        <span class=\"text-xs uppercase tracking-[0.15em] text-black/38\">{{ t(`fieldType.${field.type}`) }}</span>\n      </label>\n\n      <input\n        v-if=\"field.type === 'text'\"\n        :value=\"String(entryFields[field.key] ?? '')\"\n        class=\"form-input\"\n        :placeholder=\"field.description || field.name\"\n        @input=\"updateField(field.key, ($event.target as HTMLInputElement).value)\"\n      >\n\n      <textarea\n        v-else-if=\"field.type === 'textarea' || field.type === 'richText'\"\n        :value=\"String(entryFields[field.key] ?? '')\"\n        class=\"form-textarea\"\n        :placeholder=\"field.description || field.name\"\n        @input=\"updateField(field.key, ($event.target as HTMLTextAreaElement).value)\"\n      />\n\n      <input\n        v-else-if=\"field.type === 'number'\"\n        :value=\"Number(entryFields[field.key] ?? 0)\"\n        class=\"form-input\"\n        type=\"number\"\n        @input=\"updateField(field.key, Number(($event.target as HTMLInputElement).value))\"\n      >\n\n      <input\n        v-else-if=\"field.type === 'date'\"\n        :value=\"String(entryFields[field.key] ?? '')\"\n        class=\"form-input\"\n        type=\"datetime-local\"\n        @input=\"updateField(field.key, ($event.target as HTMLInputElement).value)\"\n      >\n\n      <textarea\n        v-else-if=\"field.type === 'json'\"\n        :value=\"asJsonText(entryFields[field.key])\"\n        class=\"form-textarea\"\n        placeholder=\"{ }\"\n        @input=\"updateField(field.key, ($event.target as HTMLTextAreaElement).value)\"\n      />\n\n      <select\n        v-else-if=\"field.type === 'media'\"\n        class=\"form-select\"\n        :value=\"String(entryFields[field.key] ?? '')\"\n        @change=\"updateField(field.key, ($event.target as HTMLSelectElement).value)\"\n      >\n        <option value=\"\">\n          {{ t('entryField.selectMedia') }}\n        </option>\n        <option v-for=\"media in mediaItems\" :key=\"media.id\" :value=\"media.id\">\n          {{ mediaLabel(media) }}\n        </option>\n      </select>\n\n      <select\n        v-else-if=\"field.type === 'reference'\"\n        class=\"form-select\"\n        :value=\"String(entryFields[field.key] ?? '')\"\n        @change=\"updateField(field.key, ($event.target as HTMLSelectElement).value)\"\n      >\n        <option value=\"\">\n          {{ t('entryField.selectEntry') }}\n        </option>\n        <option\n          v-for=\"entry in referenceEntriesForField(field, entries)\"\n          :key=\"entry.id\"\n          :value=\"entry.id\"\n        >\n          {{ entry.title }}\n        </option>\n      </select>\n\n      <label v-else-if=\"field.type === 'boolean'\" class=\"flex items-center gap-3 border border-black/10 bg-white px-4 py-3\">\n        <input\n          :checked=\"Boolean(entryFields[field.key])\"\n          type=\"checkbox\"\n          @change=\"updateField(field.key, ($event.target as HTMLInputElement).checked)\"\n        >\n        <span>{{ field.description || t('entryField.enable') }}</span>\n      </label>\n\n      <input\n        v-else\n        :value=\"String(entryFields[field.key] ?? '')\"\n        class=\"form-input\"\n        @input=\"updateField(field.key, ($event.target as HTMLInputElement).value)\"\n      >\n\n      <p v-if=\"field.description\" class=\"text-xs leading-5 text-black/50\">\n        {{ field.description }}\n      </p>\n    </div>\n  </div>\n</template>\n","<script setup lang=\"ts\">\nimport type { ContentEntry, ContentModel, MediaItem } from '~/types'\nimport { createEntryFieldDefaults, syncEntrySlug, syncEntryTitle } from '~/utils/content'\nconst { t } = useLocale()\n\nconst props = defineProps<{\n  entry?: ContentEntry | null\n  models: ContentModel[]\n  mediaItems: MediaItem[]\n  entries: ContentEntry[]\n  submitLabel: string\n  statusOptions: Array<{ label: string; value: string }>\n  initialModelId?: string\n}>()\n\nconst emit = defineEmits<{\n  submit: [payload: {\n    modelId: string\n    title: string\n    slug: string\n    status: string\n    fields: Record<string, unknown>\n  }]\n}>()\n\nconst selectedModelId = ref(props.entry?.modelId || props.initialModelId || props.models[0]?.id || '')\nconst model = computed(() => props.models.find(item => item.id === selectedModelId.value) || null)\n\nconst form = reactive({\n  title: props.entry?.title || '',\n  slug: props.entry?.slug || '',\n  status: props.entry?.status || 'draft',\n  fields: (props.entry?.fields ? structuredClone(props.entry.fields) : createEntryFieldDefaults(model.value)) as Record<string, unknown>,\n})\n\nwatch(\n  () => props.entry,\n  entry => {\n    if (!entry) {\n      return\n    }\n\n    selectedModelId.value = entry.modelId\n    form.title = entry.title\n    form.slug = entry.slug\n    form.status = entry.status\n    form.fields = structuredClone(entry.fields)\n  },\n  { immediate: true },\n)\n\nwatch(model, nextModel => {\n  if (!nextModel) {\n    return\n  }\n\n  const nextFields = createEntryFieldDefaults(nextModel)\n  for (const field of nextModel.fields) {\n    if (field.key in form.fields) {\n      nextFields[field.key] = form.fields[field.key]\n    }\n  }\n  form.fields = nextFields\n}, { immediate: true })\n\nwatch(\n  () => form.fields,\n  value => {\n    if (props.entry) {\n      return\n    }\n\n    const nextTitle = syncEntryTitle(model.value, value)\n    if (nextTitle) {\n      form.title = nextTitle\n      form.slug = syncEntrySlug(nextTitle)\n    }\n  },\n  { deep: true },\n)\n\nfunction onSubmit() {\n  emit('submit', {\n    modelId: selectedModelId.value,\n    title: form.title,\n    slug: form.slug,\n    status: form.status,\n    fields: form.fields,\n  })\n}\n</script>\n\n<template>\n  <form class=\"grid gap-6 xl:grid-cols-[minmax(0,1.4fr)_360px]\" @submit.prevent=\"onSubmit\">\n    <div class=\"space-y-6\">\n      <section class=\"grid gap-4 md:grid-cols-[260px_minmax(0,1fr)]\">\n        <label class=\"space-y-2 text-sm\">\n          <span class=\"font-medium\">{{ t('entryForm.model') }}</span>\n          <select v-model=\"selectedModelId\" class=\"form-select\" :disabled=\"Boolean(entry)\">\n            <option v-for=\"item in models\" :key=\"item.id\" :value=\"item.id\">\n              {{ item.name }}\n            </option>\n          </select>\n        </label>\n\n        <label class=\"space-y-2 text-sm\">\n          <span class=\"font-medium\">{{ t('entryForm.title') }}</span>\n          <input v-model=\"form.title\" class=\"form-input\" :placeholder=\"t('entryForm.title')\">\n        </label>\n      </section>\n\n      <section class=\"grid gap-4 md:grid-cols-[minmax(0,1fr)_220px]\">\n        <label class=\"space-y-2 text-sm\">\n          <span class=\"font-medium\">{{ t('entryForm.slug') }}</span>\n          <input v-model=\"form.slug\" class=\"form-input\" placeholder=\"entry-slug\">\n        </label>\n\n        <label class=\"space-y-2 text-sm\">\n          <span class=\"font-medium\">{{ t('entryForm.status') }}</span>\n          <select v-model=\"form.status\" class=\"form-select\">\n            <option v-for=\"option in statusOptions\" :key=\"option.value\" :value=\"option.value\">\n              {{ option.label }}\n            </option>\n          </select>\n        </label>\n      </section>\n\n      <section v-if=\"model\" class=\"soft-panel px-5 py-5\">\n        <div class=\"mb-5 flex items-start justify-between gap-4\">\n          <div>\n            <p class=\"text-xs font-semibold uppercase tracking-[0.22em] text-black/42\">\n              {{ t('entryForm.dynamicFields') }}\n            </p>\n            <h2 class=\"mt-3 text-xl font-semibold tracking-[-0.04em]\">\n              {{ model.name }}\n            </h2>\n          </div>\n          <span class=\"pill\">{{ model.apiId }}</span>\n        </div>\n\n        <EntryFieldRenderer v-model=\"form.fields\" :model=\"model\" :media-items=\"mediaItems\" :entries=\"entries\" />\n      </section>\n    </div>\n\n    <aside class=\"space-y-5\">\n      <div class=\"hard-panel space-y-4 px-5 py-5\">\n        <p class=\"text-xs font-semibold uppercase tracking-[0.2em] text-black/40\">\n          {{ t('entryForm.publishPreview') }}\n        </p>\n        <div class=\"space-y-3 text-sm leading-6 text-black/64\">\n          <p><span class=\"font-medium text-black\">{{ t('entryForm.deliveryPath') }}</span><br><code>{{ `/api/v1/content/${model?.apiId || 'model-api-id'}/${entry?.id || 'entry-id'}` }}</code></p>\n          <p><span class=\"font-medium text-black\">{{ t('entryForm.status') }}</span><br>{{ t(`status.${form.status}`) }}</p>\n          <p><span class=\"font-medium text-black\">{{ t('common.fields') }}</span><br>{{ Object.keys(form.fields).length }} {{ t('entryForm.boundFields') }}</p>\n        </div>\n      </div>\n\n      <div class=\"flex flex-wrap gap-3\">\n        <button class=\"action-button\" type=\"button\" @click=\"navigateTo('/entries')\">\n          {{ t('entryForm.cancel') }}\n        </button>\n        <button class=\"action-button\" data-variant=\"solid\" type=\"submit\">\n          <Icon name=\"lucide:save\" size=\"16\" />\n          {{ submitLabel }}\n        </button>\n      </div>\n    </aside>\n  </form>\n</template>\n"],"version":3}