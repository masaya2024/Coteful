,cAAA,GAAaG,gBAAI,MAAM,KAAK,GAAA,CAAA;AAAA,oBACrCH,YAA0D,OAAvD,OAAM,6BAAA,GAA4BG,gBAAI,MAAM,IAAI,GAAA,CAAA;AAAA,kBAAA;kBAErDH,YAIM,OAAA,MAAA;AAAA,oBAHJA,YAEO,QAAA;AAAA,sBAFD,OAAM;AAAA,sBAAQ,aAAW,MAAM,WAAM,cAAA,YAAA;AAAA,oBAAA,mBACtCH,MAAA,CAAA,EAAC,UAAW,MAAM,MAAM,EAAA,CAAA,GAAA,GAAA,CAAA,WAAA,CAAA;AAAA,kBAAA;kBAG/BG,YAEM,OAAA,EAFD,OAAM,yDACNH,MAAA,cAAA,EAAe,MAAM,SAAS,CAAA,GAAA,CAAA;AAAA,gBAAA;AAAA;;;;;;;;UAOpC,OAAOA,MAAA,CAAA,EAAC,0BAAA;AAAA,UACR,SAASA,MAAA,CAAA,EAAC,4BAAA;AAAA,QAAA;;2LAQRA,MAAA,CAAA,EAAC,wBAAA,CAAA,CAAA,0CAAA;AAIaH,oBAAAG,MAAA,UAAA,IAAR,SAAI;;UACV,KAAK,KAAK;AAAA,UACV,IAAI,KAAK;AAAA,UACV,OAAM;AAAA,QAAA;2BAJR,CAQW,GAAAC,QAAAC,UAAA,aAAA;;0DAFiBJ,eAAA,KAAK,KAAK,mEACeA,eAAA,KAAK,IAAI;;;gBAD5DK,YAA2C,OAAxC,OAAM,cAAA,GAAaG,gBAAI,KAAK,KAAK,GAAA,CAAA;AAAA,gBACpCH,YAAmE,OAAhE,OAAM,uCAAA,GAAsCG,gBAAI,KAAK,IAAI,GAAA,CAAA;AAAA,cAAA;AAAA;;;;;qNAQzDN,MAAA,CAAA,EAAC,8BAAA,CAAA,CAAA,MAAA;;QAEI,IAAG;AAAA,QAAS,OAAM;AAAA,MAAA;yBAA5B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;qCADNF,MAAA,CAAA,EAAC,iBAAA,CAAA,CAAA,EAAA;AAAA;;8CAADA,MAAA,CAAA,EAAC,iBAAA,CAAA,GAAA,CAAA;AAAA,YAAA;AAAA;;;;;UAIGA,MAAA,IAAA,GAAM,YAAY,QAAM;;sBAEhBA,MAAA,IAAA,EAAK,aAAW,CAAxB,SAAI;;YACV,KAAK,KAAK;AAAA,YACV,IAAE,UAAY,KAAK,EAAE;AAAA,YACtB,OAAM;AAAA,UAAA;6BAJR,CAaW,GAAAC,QAAAC,UAAA,aAAA;;2IALqBJ,eAAA,KAAK,QAAQ,yDACEA,eAAA,KAAK,QAAQ,sBAASE,MAAA,WAAA,EAAY,KAAK,IAAI,CAAA,2DAEhE,KAAK,OAAI,CAAA,KAASA,MAAA,CAAA,EAAC,WAAA,CAAA;;;kBAL3CG,YAMM,OAAA,EAND,OAAM,4CAAwC;AAAA,oBACjDA,YAGM,OAAA,MAAA;AAAA,sBAFJA,YAA8C,OAA3C,OAAM,cAAA,GAAaG,gBAAI,KAAK,QAAQ,GAAA,CAAA;AAAA,sBACvCH,YAA4F,KAAA,EAAzF,OAAM,6BAAA,mBAAgC,KAAK,QAAQ,IAAG,QAAGG,gBAAGN,MAAA,WAAA,EAAY,KAAK,IAAI,CAAA,GAAA,CAAA;AAAA,oBAAA;oBAEtFG,YAAgE,QAAA,EAA1D,OAAM,OAAA,mBAAU,KAAK,OAAI,CAAA,KAASH,MAAA,CAAA,EAAC,WAAA,CAAA,GAAA,CAAA;AAAA,kBAAA;;;;;;;;;;UAO5C,OAAOA,MAAA,CAAA,EAAC,wBAAA;AAAA,UACR,SAASA,MAAA,CAAA,EAAC,0BAAA;AAAA,QAAA;;;UAMRA,MAAA,OAAA,GAAO;mEACbA,MAAA,CAAA,EAAC,yBAAA,CAAA,CAAA,QAAA;AAAA;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderList","_ssrInterpolate","_withAsyncContext","_unref","_push","_parent","_createVNode","_createTextVNode","_ssrRenderComponent","_toDisplayString"],"sources":["../../../../../../../components/MetricStrip.vue","../../../../../../../pages/index.vue"],"sourcesContent":["<script setup lang=\"ts\">\ndefineProps<{\n  items: Array<{\n    label: string\n    value: string | number\n    caption: string\n  }>\n}>()\n</script>\n\n<template>\n  <section class=\"grid gap-4 md:grid-cols-3\">\n    <article\n      v-for=\"item in items\"\n      :key=\"item.label\"\n      class=\"grid-stagger soft-panel space-y-4 px-5 py-5\"\n    >\n      <p class=\"text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-black/42\">\n        {{ item.label }}\n      </p>\n      <p class=\"metric-value\">\n        {{ item.value }}\n      </p>\n      <p class=\"text-sm leading-6 text-black/55\">\n        {{ item.caption }}\n      </p>\n    </article>\n  </section>\n</template>\n","<script setup lang=\"ts\">\nimport { formatBytes, formatDateTime } from '~/utils/format'\n\nconst { adminRepository } = useCmsAdmin()\nconst { t } = useLocale()\nconst { activeProject } = useWorkspaceSession()\nconst { run } = useReloadOverlay()\n\nconst { data, pending, refresh } = await useAsyncData('dashboard', () => adminRepository.getDashboard())\n\nconst metrics = computed(() => [\n  {\n    label: t('dashboard.metricModels'),\n    value: data.value?.counts.models ?? 0,\n    caption: t('dashboard.metricModelsCaption'),\n  },\n  {\n    label: t('dashboard.metricEntries'),\n    value: data.value?.counts.entries ?? 0,\n    caption: t('dashboard.metricEntriesCaption'),\n  },\n  {\n    label: t('dashboard.metricMedia'),\n    value: data.value?.counts.media ?? 0,\n    caption: t('dashboard.metricMediaCaption'),\n  },\n])\n\nconst quickLinks = computed(() => [\n  {\n    label: t('dashboard.quickActionModel'),\n    to: '/models/new',\n    note: t('dashboard.quickActionModelNote'),\n  },\n  {\n    label: t('dashboard.quickActionEntry'),\n    to: '/entries/new',\n    note: t('dashboard.quickActionEntryNote'),\n  },\n  {\n    label: t('dashboard.quickActionMedia'),\n    to: '/media/new',\n    note: t('dashboard.quickActionMediaNote'),\n  },\n])\n\nasync function refreshDashboard() {\n  await run(() => refresh())\n}\n</script>\n\n<template>\n  <div class=\"space-y-8\">\n    <PageHeading\n      :eyebrow=\"t('dashboard.eyebrow')\"\n      :title=\"t('dashboard.title')\"\n      :description=\"activeProject?.name ? `${t('dashboard.description')} (${activeProject.name})` : t('dashboard.description')\"\n    >\n      <template #actions>\n        <button class=\"action-button\" type=\"button\" @click=\"refreshDashboard()\">\n          <Icon name=\"lucide:arrow-up-right\" size=\"16\" />\n          {{ t('common.refreshSnapshot') }}\n        </button>\n      </template>\n    </PageHeading>\n\n    <MetricStrip :items=\"metrics\" />\n\n    <div class=\"grid gap-6 xl:grid-cols-[minmax(0,1.3fr)_360px]\">\n      <section class=\"space-y-6\">\n        <article class=\"soft-panel px-5 py-5\">\n          <div class=\"flex items-center justify-between border-b border-black/10 pb-4\">\n            <div>\n              <p class=\"text-xs font-semibold uppercase tracking-[0.2em] text-black/42\">\n                {{ t('dashboard.recentModelsEyebrow') }}\n              </p>\n              <h2 class=\"mt-2 text-xl font-semibold tracking-[-0.04em]\">\n                {{ t('dashboard.recentModelsTitle') }}\n              </h2>\n            </div>\n            <NuxtLink class=\"action-button px-3 py-2 text-sm\" to=\"/models\">\n              {{ t('actions.openModels') }}\n            </NuxtLink>\n          </div>\n\n          <div v-if=\"data?.recentModels.length\" class=\"data-grid mt-4\">\n            <NuxtLink\n              v-for=\"model in data.recentModels\"\n              :key=\"model.id\"\n              :to=\"`/models/${model.id}`\"\n              class=\"grid gap-2 px-1 py-4 md:grid-cols-[minmax(0,1fr)_160px_120px]\"\n            >\n              <div>\n                <p class=\"font-medium\">{{ model.name }}</p>\n                <p class=\"mt-1 text-sm text-black/55\">{{ model.description }}</p>\n              </div>\n              <div class=\"text-sm text-black/55\">\n                <p class=\"font-medium text-black\">{{ model.apiId }}</p>\n                <p>{{ model.fields.length }} {{ t('common.fields') }}</p>\n              </div>\n              <div class=\"text-sm text-black/55 md:text-right\">\n                <span class=\"pill\" :data-tone=\"model.status === 'active' ? 'success' : 'warning'\">\n                  {{ t(`status.${model.status}`) }}\n                </span>\n                <p class=\"mt-2\">{{ formatDateTime(model.updatedAt) }}</p>\n              </div>\n            </NuxtLink>\n          </div>\n\n          <EmptyState\n            v-else\n            :title=\"t('dashboard.noModelsTitle')\"\n            :message=\"t('dashboard.noModelsMessage')\"\n          />\n        </article>\n\n        <article class=\"soft-panel px-5 py-5\">\n          <div class=\"flex items-center justify-between border-b border-black/10 pb-4\">\n            <div>\n              <p class=\"text-xs font-semibold uppercase tracking-[0.2em] text-black/42\">\n                {{ t('dashboard.recentEntriesEyebrow') }}\n              </p>\n              <h2 class=\"mt-2 text-xl font-semibold tracking-[-0.04em]\">\n                {{ t('dashboard.recentEntriesTitle') }}\n              </h2>\n            </div>\n            <NuxtLink class=\"action-button px-3 py-2 text-sm\" to=\"/entries\">\n              {{ t('actions.openEntries') }}\n            </NuxtLink>\n          </div>\n\n          <div v-if=\"data?.recentEntries.length\" class=\"data-grid mt-4\">\n            <NuxtLink\n              v-for=\"entry in data.recentEntries\"\n              :key=\"entry.id\"\n              :to=\"`/entries/${entry.id}`\"\n              class=\"grid gap-2 px-1 py-4 md:grid-cols-[minmax(0,1fr)_120px_160px]\"\n            >\n              <div>\n                <p class=\"font-medium\">{{ entry.title }}</p>\n                <p class=\"mt-1 text-sm text-black/55\">{{ entry.slug }}</p>\n              </div>\n              <div>\n                <span class=\"pill\" :data-tone=\"entry.status === 'published' ? 'success' : 'warning'\">\n                  {{ t(`status.${entry.status}`) }}\n                </span>\n              </div>\n              <div class=\"text-sm text-black/55 md:text-right\">\n                {{ formatDateTime(entry.updatedAt) }}\n              </div>\n            </NuxtLink>\n          </div>\n\n          <EmptyState\n            v-else\n            :title=\"t('dashboard.noEntriesTitle')\"\n            :message=\"t('dashboard.noEntriesMessage')\"\n          />\n        </article>\n      </section>\n\n      <aside class=\"space-y-6\">\n        <article class=\"hard-panel px-5 py-5\">\n          <p class=\"text-xs font-semibold uppercase tracking-[0.2em] text-black/42\">\n            {{ t('dashboard.quickActions') }}\n          </p>\n          <div class=\"mt-4 space-y-3\">\n            <NuxtLink\n              v-for=\"link in quickLinks\"\n              :key=\"link.to\"\n              :to=\"link.to\"\n              class=\"block border border-black/12 bg-white px-4 py-4 transition hover:border-black/35\"\n            >\n              <p class=\"font-medium\">{{ link.label }}</p>\n              <p class=\"mt-2 text-sm leading-6 text-black/55\">{{ link.note }}</p>\n            </NuxtLink>\n          </div>\n        </article>\n\n        <article class=\"hard-panel px-5 py-5\">\n          <div class=\"flex items-center justify-between\">\n            <p class=\"text-xs font-semibold uppercase tracking-[0.2em] text-black/42\">\n              {{ t('dashboard.latestMediaEyebrow') }}\n            </p>\n            <NuxtLink to=\"/media\" class=\"text-sm font-medium underline decoration-black/20 underline-offset-4\">\n              {{ t('actions.viewAll') }}\n            </NuxtLink>\n          </div>\n\n          <div v-if=\"data?.recentMedia.length\" class=\"data-grid mt-4\">\n            <NuxtLink\n              v-for=\"item in data.recentMedia\"\n              :key=\"item.id\"\n              :to=\"`/media/${item.id}`\"\n              class=\"grid gap-2 px-1 py-4\"\n            >\n              <div class=\"flex items-start justify-between gap-4\">\n                <div>\n                  <p class=\"font-medium\">{{ item.fileName }}</p>\n                  <p class=\"mt-1 text-sm text-black/55\">{{ item.mimeType }} · {{ formatBytes(item.size) }}</p>\n                </div>\n                <span class=\"pill\">{{ item.tags?.[0] || t('nav.media') }}</span>\n              </div>\n            </NuxtLink>\n          </div>\n\n          <EmptyState\n            v-else\n            :title=\"t('dashboard.noMediaTitle')\"\n            :message=\"t('dashboard.noMediaMessage')\"\n          />\n        </article>\n      </aside>\n    </div>\n\n    <div v-if=\"pending\" class=\"text-sm text-black/50\">\n      {{ t('common.loadingDashboard') }}\n    </div>\n  </div>\n</template>\n"],"version":3}